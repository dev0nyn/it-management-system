# Database
DATABASE_URL=postgres://user:password@localhost:5432/itms

# Redis
REDIS_URL=redis://localhost:6379

# JWT  (Vercel AND Railway both need these)
JWT_SECRET=change-me

# SMTP / Notifications
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
NOTIFICATION_FROM="IT Management <no-reply@example.com>"

# Monitoring worker
MONITORING_DEFAULT_INTERVAL_SEC=60
MONITORING_FAIL_THRESHOLD=3

# App
LOG_LEVEL=info
NODE_ENV=development

# Required in production (Vercel): base URL of the Railway API server.
# All API calls from the frontend are routed here — Bearer tokens work cross-domain.
# Leave empty for local dev (Next.js dev server handles /api/* locally).
NEXT_PUBLIC_API_URL=
