# Database
DATABASE_URL=postgres://user:password@localhost:5432/itms

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=change-me
JWT_REFRESH_SECRET=change-me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# SMTP / Notifications (legacy — set RESEND_API_KEY to use Resend instead)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
NOTIFICATION_FROM="IT Management <no-reply@example.com>"
# Resend (email provider — set this to enable real email delivery)
RESEND_API_KEY=re_your_api_key_here


# Monitoring worker
MONITORING_DEFAULT_INTERVAL_SEC=60
MONITORING_FAIL_THRESHOLD=3

# App
LOG_LEVEL=info
NODE_ENV=development

# Required in production (Vercel): base URL of the Railway API server.
# All API calls from the frontend are routed here — Bearer tokens work cross-domain.
# Leave empty for local dev (Next.js dev server handles /api/* locally).
NEXT_PUBLIC_API_URL=

# Required in production (Railway): Vercel domain allowed for CORS.
# Set to your Vercel deployment URL e.g. https://your-app.vercel.app
# Leave empty for local dev (falls back to "*").
CORS_ORIGIN=

RESEND_API_KEY=

# MCP Server
MCP_SERVER_PORT=3100
MCP_INTERNAL_API_URL=http://localhost:3000
MCP_INTERNAL_API_SECRET=<pre-generated JWT for MCP server internal calls>
MCP_API_KEY=<key clients use to authenticate with MCP server>
MCP_API_KEY_ROLE=admin
