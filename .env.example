# Database
DATABASE_URL=postgres://user:password@localhost:5432/itms

# Redis
REDIS_URL=redis://localhost:6379

# JWT  (Vercel AND Railway both need these)
JWT_SECRET=change-me

# SMTP / Notifications
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
NOTIFICATION_FROM="IT Management <no-reply@example.com>"

# Monitoring worker
MONITORING_DEFAULT_INTERVAL_SEC=60
MONITORING_FAIL_THRESHOLD=3

# App
LOG_LEVEL=info
NODE_ENV=development

# NOTE: NEXT_PUBLIC_API_URL is intentionally not set.
# Auth (login/logout) uses Next.js API routes on the same Vercel deployment so
# that httpOnly session cookies work on the same domain.  Do not set this var
# unless you have solved the cross-domain cookie problem.
