# Copy this file to .env and fill in real values. Never commit .env.

# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/itms

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Email / notifications
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=no-reply@example.com
SMTP_PASS=change-me
NOTIFICATION_FROM="IT Management <no-reply@example.com>"

# Monitoring worker
MONITORING_DEFAULT_INTERVAL_SEC=60
MONITORING_FAIL_THRESHOLD=3

# General
LOG_LEVEL=info
NODE_ENV=development

# Supabase (CI/CD — not needed for local dev with docker-compose)
SUPABASE_API_KEY=your-supabase-personal-access-token
SUPABASE_PROJECT_REF=your-supabase-project-ref
SUPABASE_DB_PASSWORD=your-supabase-db-password

# Railway (CI/CD)
RAILWAY_TOKEN=your-railway-api-token
RAILWAY_SERVICE_ID=your-railway-service-id
RAILWAY_API_URL=https://api.yourapp.railway.app

# Vercel (CI/CD)
VERCEL_TOKEN=your-vercel-token
VERCEL_ORG_ID=your-vercel-org-id
VERCEL_PROJECT_ID=your-vercel-project-id
VERCEL_URL=https://yourapp.vercel.app
